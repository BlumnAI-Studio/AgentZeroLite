<Window x:Class="AgentZeroWpf.UI.Components.FloatingScrapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scrap — Floating"
        Width="900" Height="600"
        MinWidth="480" MinHeight="320"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="#1E1E1E"
        Icon="/agentzero.ico"
        WindowStartupLocation="Manual"
        ShowInTaskbar="True">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg"     Color="#252526"/>
        <SolidColorBrush x:Key="ToolbarBg"   Color="#2D2D30"/>
        <SolidColorBrush x:Key="BorderColor" Color="#3E3E42"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#D4D4D4"/>
        <SolidColorBrush x:Key="TextDim"     Color="#858585"/>
        <SolidColorBrush x:Key="EditorBg"    Color="#1E1E1E"/>
        <SolidColorBrush x:Key="InputBg"     Color="#1F1F1F"/>
        <SolidColorBrush x:Key="InputBorder" Color="#3E3E42"/>
        <SolidColorBrush x:Key="CyberCyanBrush"    Color="#3794FF"/>
        <SolidColorBrush x:Key="CyberMintBrush"    Color="#7CFDB0"/>
        <SolidColorBrush x:Key="CyberMagentaBrush" Color="#C586C0"/>
        <SolidColorBrush x:Key="CyberPurpleBrush"  Color="#4EC9B0"/>
        <SolidColorBrush x:Key="CyberYellowBrush"  Color="#DCDCAA"/>
        <SolidColorBrush x:Key="SelectionBrush"    Color="#264F78"/>

        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9D9D9D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DockBackBtn" TargetType="Button" BasedOn="{StaticResource TitleBtn}">
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Styles consumed by ScrapPagePanel through DynamicResource -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{StaticResource CyberCyanBrush}"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SelectionBrush" Value="{StaticResource SelectionBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="BorderBrush" Value="{StaticResource CyberCyanBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource CyberCyanBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar (drag region) -->
            <Border Grid.Row="0" Background="#1F2A4A"
                    MouseLeftButtonDown="OnTitleBarDrag">
                <DockPanel LastChildFill="False" Margin="8,0">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource CyberMintBrush}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="SCRAP" Foreground="{StaticResource CyberMintBrush}"
                                   FontFamily="Consolas" FontSize="10" FontWeight="Bold"
                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="floating" Foreground="{StaticResource TextDim}"
                                   FontFamily="Consolas" FontSize="10"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnDockBack" Content="⤡  Dock back"
                                Style="{StaticResource DockBackBtn}"
                                ToolTip="Return Scrap to the main window"
                                Click="OnDockBackClick"/>
                        <Button Content="✕" Style="{StaticResource TitleBtn}"
                                FontWeight="Bold"
                                ToolTip="Close = dock back"
                                Click="OnDockBackClick"
                                Margin="4,0,0,0"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Reparented ScrapPagePanel lives here -->
            <Grid x:Name="contentHost" Grid.Row="1" Background="{StaticResource EditorBg}"/>
        </Grid>
    </Border>
</Window>
