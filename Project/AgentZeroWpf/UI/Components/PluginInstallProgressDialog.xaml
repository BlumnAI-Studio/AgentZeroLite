<Window x:Class="AgentZeroWpf.UI.Components.PluginInstallProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Installing Plugin"
        Width="560" Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        Background="#1B1B1C">
    <Window.Resources>
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>     <!-- caption -->
            <RowDefinition Height="Auto"/>     <!-- detail -->
            <RowDefinition Height="Auto"/>     <!-- progress bar -->
            <RowDefinition Height="Auto"/>     <!-- counters -->
            <RowDefinition Height="*"/>        <!-- spacer -->
            <RowDefinition Height="Auto"/>     <!-- buttons -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="tbCaption" Text="Preparing…"
                   FontSize="14" FontWeight="SemiBold" Foreground="#E5E5E5"/>

        <!-- Detail is one-line mono so a long file path truncates with an ellipsis
             instead of pushing the layout. -->
        <TextBlock Grid.Row="1" x:Name="tbDetail" Text=""
                   FontSize="11" Foreground="#9D9D9D" FontFamily="Consolas"
                   Margin="0,4,0,10"
                   TextTrimming="CharacterEllipsis"/>

        <ProgressBar Grid.Row="2" x:Name="pb" Height="14"
                     Background="#0F0F22" BorderBrush="#2A2A5E" Foreground="#0A84FF"
                     Minimum="0" Maximum="100" Value="0"
                     IsIndeterminate="True"/>

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <TextBlock x:Name="tbCounters" HorizontalAlignment="Left"
                       FontSize="11" Foreground="#9D9D9D" FontFamily="Consolas"/>
            <TextBlock x:Name="tbPercent" HorizontalAlignment="Right"
                       FontSize="11" Foreground="#9D9D9D" FontFamily="Consolas"/>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="btnCancel" Content="Cancel" Style="{StaticResource GhostButton}"
                    Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
